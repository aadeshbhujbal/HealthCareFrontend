{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": ["node"],
    "composite": true,
    "declaration": true,
    "paths": {
      "@health-care-frontend/design-system": [
        "../../libs/design-system/src/index.ts"
      ],
      "@health-care-frontend/shared-services": [
        "../../libs/shared-services/src/index.ts"
      ]
    }
  },
  "files": [
    "../../node_modules/@nx/expo/typings/svg.d.ts",
    "../../node_modules/@types/react-native/index.d.ts"
  ],
  "include": [
    "src/**/*",
    "../../libs/design-system/src/**/*",
    "../../libs/shared-services/src/**/*"
  ],
  "exclude": ["jest.config.ts", "**/*.spec.ts", "**/*.test.ts"]
}
